{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CosmoSecure",
  "version": "1.0.0",
  "identifier": "com.cosmosecure.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "CosmoSecure",
        "width": 1340,
        "height": 800,
        "decorations": false,
        "minWidth": 1200,
        "minHeight": 765,
        "transparent": true,
        "center": true,
        "shadow": false,
        "contentProtected": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Security, Utilities",
    "licenseFile": "../LICENSE",
    "shortDescription": "Secure password manager with zero-knowledge encryption",
    "longDescription": "CosmoSecure is a modern password manager that keeps your credentials safe with military-grade encryption and zero-knowledge architecture.",
    "copyright": "Copyright © 2025 akash2061. Licensed under Apache 2.0.",
    "publisher": "akash2061"
  }
}